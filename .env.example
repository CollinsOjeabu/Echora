# Echora — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to source control.

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk v7 redirect configuration
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Get from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# Required for AI post generation (Phase F)
OPENAI_API_KEY=

# Required for URL content scraping (Phase E)
FIRECRAWL_API_KEY=

# Set in Convex dashboard — NOT in .env.local
# OPENAI_API_KEY=sk-...
# FIRECRAWL_API_KEY=fc-...
# CLERK_WEBHOOK_SECRET=whsec_...
